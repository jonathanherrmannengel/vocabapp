<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.RBV" parent="Theme.Material3.DayNight">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/ijblue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/highlight</item>
        <item name="android:textColorLink">@color/hyperlink</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <!-- Action bar -->
        <item name="actionBarTheme">@style/Theme.RBV.ActionBar</item>
        <item name="actionOverflowMenuStyle">@style/Theme.RBV.ActionBarOverflow</item>
        <!-- Action mode -->
        <item name="actionModeStyle">@style/Theme.RBV.ActionMode</item>
        <!-- Default background color -->
        <item name="android:windowBackground">@color/background_default</item>
        <!-- No animations -->
        <item name="android:windowAnimationStyle">@null</item>
        <!-- Splash screen -->
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/rbv_colors</item>
    </style>

    <style name="Theme.RBV.ActionBar" parent="@style/ThemeOverlay.Material3.ActionBar">
        <item name="colorSurfaceContainer">@android:color/transparent</item>
        <item name="elevationOverlayColor">@android:color/transparent</item>
        <item name="colorOnSurface">@color/default_text</item>
        <item name="android:tint">?attr/colorOnSurface</item>
    </style>

    <style name="Theme.RBV.ActionBarOverflow" parent="@style/Widget.Material3.PopupMenu.Overflow">
        <item name="android:popupBackground">@color/background_default</item>
    </style>

    <style name="Theme.RBV.ActionMode" parent="@style/Widget.Material3.ActionMode">
        <item name="background">@android:color/transparent</item>
    </style>
</resources>
